{
  "info": {
    "name": "Udemy Clone API",
    "description": "Complete API collection for the Udemy Clone LMS",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5001/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"@Password1\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@udemy.com\",\n  \"password\": \"@Admin3124\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Get Courses",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/courses"
          }
        },
        {
          "name": "Get Featured Courses",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/courses/featured"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "Checkout",
      "item": [
        {
          "name": "Validate Coupon",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/checkout/validate-coupon",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"TEST10\",\n  \"courseId\": \"COURSE_ID\"\n}"
            }
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/checkout/create-order",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": \"COURSE_ID\",\n  \"gatewayId\": \"GATEWAY_ID\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Learning",
      "item": [
        {
          "name": "Get Progress",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/learning/progress/:courseId",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Mark Lesson Complete",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/learning/progress/:courseId/lesson/:lessonId",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    }
  ]
}
