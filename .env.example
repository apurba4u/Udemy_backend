# Server Configuration
PORT=5001
NODE_ENV=production

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/udemy_clone?retryWrites=true&w=majority

# Better Auth Configuration
BETTER_AUTH_SECRET=generate_a_strong_random_string_here
BETTER_AUTH_URL=https://your-backend-domain.onrender.com

# JWT Configuration
JWT_SECRET=generate_a_strong_random_string_here
JWT_EXPIRES_IN=7d

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin Default Credentials
ADMIN_EMAIL=admin@udemy.com
ADMIN_PASSWORD=your_secure_admin_password

# CORS Configuration - your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# ImgBB (Image Upload)
IMGBB_API_KEY=
